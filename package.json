{
  "name": "zeladoria-inteligente",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "prepare": "husky",
    "build": "npm run build -w @zeladoria-inteligente/api",
    "test": "npm run test:api && npm run test:web",
    "test:api": "npm run test -w @zeladoria-inteligente/api",
    "test:web": "npm run test -w @zeladoria-inteligente/web",
    "dev:api": "npm run start:dev -w @zeladoria-inteligente/api",
    "dev:web": "npm run dev -w @zeladoria-inteligente/web"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^15.4.3",
    "prettier": "^3.4.2"
  },
  "lint-staged": {
    "apps/api/src/**/*.ts": "prettier --write",
    "apps/web/**/*.{ts,tsx,js,jsx,json,css,md}": "prettier --write"
  }
}
