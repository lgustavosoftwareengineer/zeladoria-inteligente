{
  "name": "zeladoria-inteligente",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "prepare": "node --eval \"process.env.CI || process.exit(1)\" || husky",
    "test": "npm run api:test && npm run web:test",
    "api:build": "npm run build -w @zeladoria-inteligente/api",
    "api:test": "npm run test -w @zeladoria-inteligente/api",
    "api:dev": "npm run start:dev -w @zeladoria-inteligente/api",
    "api:migration:generate": "npm run migration:generate -w @zeladoria-inteligente/api",
    "api:migration:run": "npm run migration:run -w @zeladoria-inteligente/api",
    "api:migration:revert": "npm run migration:revert -w @zeladoria-inteligente/api",
    "web:test": "npm run test -w @zeladoria-inteligente/web",
    "web:dev": "npm run dev -w @zeladoria-inteligente/web"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^15.4.3",
    "prettier": "^3.4.2"
  },
  "lint-staged": {
    "apps/api/src/**/*.ts": "prettier --write",
    "apps/web/**/*.{ts,tsx,js,jsx,json,css,md}": "prettier --write"
  }
}
